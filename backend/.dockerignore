# Compiled binaries / build output (rebuilt inside the image)
bin
out
*.exe
vendor

# Version control / CI
.git
.gitignore
.github

# Test artifacts
e2e/__screens__
e2e/test-results

# Local env (never bake secrets into the image)
.env
.env.*
!.env.example

# Logs / OS / editor cruft
*.log
.DS_Store
.idea
.vscode
