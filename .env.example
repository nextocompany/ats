# Copy to .env for local development:  cp .env.example .env
# NOTE: docker-compose sets the api/worker connection URLs itself using internal
# service hostnames (postgres/redis/azurite). The values below are the HOST-side
# values used by `make migrate-up` and any binaries you run directly on the host.

# ---- Runtime ----
ENV=development
HTTP_PORT=8080
WORKER_PORT=8081

# ---- Host-side connections (localhost) ----
DB_URL=postgres://hruser:hrpass@localhost:5432/hr_db?sslmode=disable
REDIS_URL=redis://localhost:6379

# ---- Postgres container credentials (consumed by docker-compose) ----
POSTGRES_DB=hr_db
POSTGRES_USER=hruser
POSTGRES_PASSWORD=hrpass

# ---- Azurite (host-side). The Azurite dev account key is public, not a secret ----
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
AZURE_BLOB_CONTAINER=resumes

# ---- Auth ----
JWT_SECRET=dev-only-change-me

# ---- Sprint 1+ placeholders (NOT used in Sprint 0) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=hr-screening-gpt4o
# AI pre-interview (slice 2.5): max questions the AI asks. Reuses AZURE_OPENAI_* above.
INTERVIEW_MAX_TURNS=6
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
# LINE Login channel secret + OAuth callback (required when LINE_PROVIDER=real).
# Callback must EXACTLY match the one registered on the LINE Login channel, e.g.
# https://<api-host>/api/v1/public/line/callback
LINE_CHANNEL_SECRET=
LINE_LOGIN_CALLBACK_URL=
# Prompt candidates to add the Official Account as a friend during login so LINE
# push can reach them: "aggressive" (default), "normal", or "" (off). Requires the
# Login channel to be linked to the Messaging API channel in the LINE console.
LINE_LOGIN_BOT_PROMPT=aggressive
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
PS_IB_BASE_URL=
PS_IB_CLIENT_ID=
PS_IB_CLIENT_SECRET=
# Required when PS_PROVIDER=real. PeopleSoft signs each webhook body:
# X-PS-Signature: hex(HMAC-SHA256(PS_WEBHOOK_SECRET, raw-request-body))
PS_WEBHOOK_SECRET=

# ---- PDPA retention sweep (Sprint 7) ----
# Disabled by default — enable ONLY in environments that should erase candidate
# PII after the retention window. RETENTION_DAYS is the documented ≤1-year promise.
# Cron runs on the single-replica scheduler service (daily 03:30 by default).
RETENTION_SWEEP_ENABLED=false
RETENTION_DAYS=365
RETENTION_SWEEP_CRON=30 3 * * *
RETENTION_SWEEP_BATCH=500

# ---- Public API rate limit (Sprint 7) ----
# Max requests per IP per minute on /api/v1/public/*. Enforced cluster-wide via
# Redis (shared across api replicas).
RATE_LIMIT_PUBLIC_MAX=30

# ---- Auth cleanup (candidate membership) ----
# Scheduler job (scheduler→worker) that deletes expired/consumed email_otps and
# expired/revoked candidate_sessions so those tables don't grow unbounded. Benign
# housekeeping (removes only already-dead auth rows) → ENABLED by default, unlike
# the retention sweep above. Runs on the single-replica scheduler.
AUTH_CLEANUP_ENABLED=true
AUTH_CLEANUP_CRON=15 3 * * *
AUTH_CLEANUP_BATCH=500

# ---- Production config guards (Sprint 8) ----
# Comma-separated proxy IPs/CIDRs whose X-Forwarded-For is trusted for client-IP
# resolution (e.g. the prod ingress/LB range, such as the ACA ingress CIDR).
# Empty in dev ⇒ direct peer IP. REQUIRED in prod for correct per-client rate
# limiting; never set ProxyHeader trust without this allowlist (X-Forwarded-For
# is client-spoofable otherwise).
TRUSTED_PROXIES=
# CORS allowlist for browser clients. Defaults to localhost for dev. When
# ENV != development the app FAILS TO START if this still contains localhost — set
# it to the real HR console + career portal origins.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
# When ENV != development the app also FAILS TO START if JWT_SECRET is empty.
# Provider flags (AI_PROVIDER/AI_SEARCH_PROVIDER use mock|azure; AUTH/PS/LINE/
# NOTIFY/GOOGLE/EMAIL use mock|real) are value-validated at startup — a typo fails fast.

# ---- Candidate membership (career-portal accounts) ----
# Persistent candidate accounts: signup/login via LINE / Google / email-OTP, an
# httpOnly session, a saved profile + resume, and account-first apply. All three
# providers default to mock so local/CI need no credentials.

# Google Login (OAuth web flow, mirrors LINE). Required when GOOGLE_PROVIDER=real.
# Callback must EXACTLY match the Authorized redirect URI in Google Cloud, e.g.
# https://<api-host>/api/v1/public/auth/google/callback
GOOGLE_PROVIDER=mock
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Email delivery for the passwordless email-OTP (Azure Communication Services).
# Required when EMAIL_PROVIDER=real. ACS has no Go SDK — the sender signs REST
# requests with the access key. ACS_EMAIL_SENDER must be a verified sender address.
EMAIL_PROVIDER=mock
ACS_EMAIL_ENDPOINT=
ACS_EMAIL_ACCESS_KEY=
ACS_EMAIL_SENDER=

# Session + OTP tuning (durations are Go time.ParseDuration strings).
# IMPORTANT (prod): the portal and api are cross-site (azurecontainerapps.io is a
# public suffix), so the session cookie is set SameSite=None; Secure automatically
# when ENV != development and every portal fetch sends credentials. CORS_ALLOW_ORIGINS
# must list the exact portal origin (no wildcard) for the cookie to flow.
CANDIDATE_SESSION_TTL=720h
CANDIDATE_SESSION_COOKIE=cp_session
EMAIL_OTP_TTL=10m
