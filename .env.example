# Copy to .env for local development:  cp .env.example .env
# NOTE: docker-compose sets the api/worker connection URLs itself using internal
# service hostnames (postgres/redis/azurite). The values below are the HOST-side
# values used by `make migrate-up` and any binaries you run directly on the host.

# ---- Runtime ----
ENV=development
HTTP_PORT=8080
WORKER_PORT=8081

# ---- Host-side connections (localhost) ----
DB_URL=postgres://hruser:hrpass@localhost:5432/hr_db?sslmode=disable
REDIS_URL=redis://localhost:6379

# ---- Postgres container credentials (consumed by docker-compose) ----
POSTGRES_DB=hr_db
POSTGRES_USER=hruser
POSTGRES_PASSWORD=hrpass

# ---- Azurite (host-side). The Azurite dev account key is public, not a secret ----
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
AZURE_BLOB_CONTAINER=resumes

# ---- Auth ----
JWT_SECRET=dev-only-change-me

# ---- Sprint 1+ placeholders (NOT used in Sprint 0) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=hr-screening-gpt4o
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
PS_IB_BASE_URL=
PS_IB_CLIENT_ID=
PS_IB_CLIENT_SECRET=
# Required when PS_PROVIDER=real. PeopleSoft signs each webhook body:
# X-PS-Signature: hex(HMAC-SHA256(PS_WEBHOOK_SECRET, raw-request-body))
PS_WEBHOOK_SECRET=

# ---- PDPA retention sweep (Sprint 7) ----
# Disabled by default — enable ONLY in environments that should erase candidate
# PII after the retention window. RETENTION_DAYS is the documented ≤1-year promise.
# Cron runs on the single-replica scheduler service (daily 03:30 by default).
RETENTION_SWEEP_ENABLED=false
RETENTION_DAYS=365
RETENTION_SWEEP_CRON=30 3 * * *
RETENTION_SWEEP_BATCH=500

# ---- Public API rate limit (Sprint 7) ----
# Max requests per IP per minute on /api/v1/public/*. Enforced cluster-wide via
# Redis (shared across api replicas).
RATE_LIMIT_PUBLIC_MAX=30
